<Page x:Class="ShiftTracker.Views.ShiftsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Журнал змін">

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                    <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,40,0,-40" To="20" Duration="0:0:0.6">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="15" Padding="20" Margin="0,0,20,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.1" Direction="270"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="{DynamicResource sh_AddShift}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,25"/>

                <TextBlock Text="{DynamicResource sh_Date}" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                <DatePicker x:Name="dpDate" Margin="0,0,0,20" Background="#F3F4F6" Foreground="Black" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="5"/>

                <TextBlock Text="{DynamicResource sh_Hours}" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                <TextBox x:Name="txtHours" Margin="0,0,0,20" Padding="10" Background="{DynamicResource InputBackground}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"/>

                <TextBlock Text="{DynamicResource sh_Notes}" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                <TextBox x:Name="txtNotes" Height="90" TextWrapping="Wrap" Margin="0,0,0,30" Padding="10" Background="{DynamicResource InputBackground}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"/>

                <Button Content="{DynamicResource sh_SaveBtn}" Click="BtnSave_Click" Padding="15" Background="{DynamicResource AccentColor}" Foreground="#11111B" FontSize="14" FontWeight="ExtraBold" Cursor="Hand" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="15" Padding="25">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.1" Direction="270"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{DynamicResource sh_History}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

                <DataGrid x:Name="gridShifts" Grid.Row="1" AutoGenerateColumns="False" 
                          Background="Transparent" RowBackground="Transparent" Foreground="{DynamicResource TextPrimary}"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderColor}"
                          BorderThickness="0" CanUserAddRows="False">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource AppBackground}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
                                    <Setter Property="Foreground" Value="#11111B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            <Setter Property="Margin" Value="0,3"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource sh_ColDate}" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="120"/>
                        <DataGridTextColumn Header="{DynamicResource sh_ColHours}" Binding="{Binding HoursWorked}" Width="80"/>
                        <DataGridTextColumn Header="{DynamicResource sh_ColEarned}" Binding="{Binding TotalEarned, StringFormat={}{0:F2}}" Width="130"/>
                        <DataGridTextColumn Header="{DynamicResource sh_ColNotes}" Binding="{Binding Notes}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Grid.Row="2" Content="{DynamicResource sh_DelBtn}" Click="BtnDelete_Click" Margin="0,20,0,0" Padding="15,12" Background="#F38BA8" Foreground="#11111B" FontSize="14" FontWeight="Bold" Cursor="Hand" BorderThickness="0" HorizontalAlignment="Right">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>