<Page x:Class="ShiftTracker.Views.StatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Статистика">

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                    <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,40,0,-40" To="20" Duration="0:0:0.6">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource st_Title}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="10,0,0,30"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="15" Padding="25" Margin="0,0,15,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.1" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{DynamicResource st_TotalEarned}" Foreground="{DynamicResource TextSecondary}" FontSize="16" Margin="0,0,0,15"/>
                    <TextBlock x:Name="txtTotalEarned" Text="0" Foreground="{DynamicResource AccentColor}" FontSize="34" FontWeight="ExtraBold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="15" Padding="25" Margin="10,0,10,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.1" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{DynamicResource st_TotalHours}" Foreground="{DynamicResource TextSecondary}" FontSize="16" Margin="0,0,0,15"/>
                    <TextBlock x:Name="txtTotalHours" Text="0" Foreground="#A6E3A1" FontSize="34" FontWeight="ExtraBold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource CardBackground}" CornerRadius="15" Padding="25" Margin="15,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.1" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{DynamicResource st_AvgShift}" Foreground="{DynamicResource TextSecondary}" FontSize="16" Margin="0,0,0,15"/>
                    <TextBlock x:Name="txtAverageShift" Text="0" Foreground="#F9E2AF" FontSize="34" FontWeight="ExtraBold"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,30,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="15" Padding="25" Margin="0,0,15,0" VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.1" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{DynamicResource st_GoalTitle}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>
                    <TextBlock Text="{DynamicResource st_GoalDesc}" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,20"/>

                    <ProgressBar x:Name="pbGoal" Minimum="0" Maximum="10000" Height="25" Margin="0,0,0,15" Background="{DynamicResource InputBackground}" Foreground="{DynamicResource AccentColor}" BorderThickness="0"/>

                    <TextBlock x:Name="txtGoalProgress" Text="0 / 10 000 (0%)" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="15" Padding="25" Margin="15,0,0,0" VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.1" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{DynamicResource st_RecordsTitle}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

                    <TextBlock Text="{DynamicResource st_BestShift}" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,5"/>
                    <TextBlock x:Name="txtBestShift" Text="{DynamicResource st_NoData}" Foreground="#F9E2AF" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Text="{DynamicResource st_LongestShift}" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,5"/>
                    <TextBlock x:Name="txtLongestShift" Text="{DynamicResource st_NoData}" Foreground="#A6E3A1" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>