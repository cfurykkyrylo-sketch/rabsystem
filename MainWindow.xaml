<Window x:Class="ShiftTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🚀 rabsystem" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BorderColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource CardBackground}" BorderThickness="0" Panel.ZIndex="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.15" Direction="0"/>
            </Border.Effect>

            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Top" Margin="0,40,0,0">
                    <TextBlock Text="🚀 rabsystem" FontSize="28" FontWeight="ExtraBold" 
                               Foreground="{DynamicResource AccentColor}" 
                               HorizontalAlignment="Center" Margin="0,0,0,50"/>

                    <Button Content="{DynamicResource m_Home}" Click="NavHome_Click" Style="{StaticResource MenuButtonStyle}"/>

                    <Button Content="{DynamicResource m_Journal}" Click="NavShifts_Click" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="{DynamicResource m_Stats}" Click="NavStats_Click" Style="{StaticResource MenuButtonStyle}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,30">
                    <Border Height="1" Background="{DynamicResource BorderColor}" Margin="20,0,20,20"/>
                    <Button Content="{DynamicResource m_Settings}" Click="NavSettings_Click" Style="{StaticResource MenuButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="Transparent"/>
    </Grid>
</Window>